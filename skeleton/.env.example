# ⚠️ 生产环境禁止使用以下默认值！Production: NEVER use these defaults!
APP_APP_NAME=Koi Service
APP_DEBUG=true
APP_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/koi_service
APP_REDIS_URL=redis://localhost:6379/0
# ⚠️ 生产环境必须替换为强随机密钥 / Production: MUST use a strong random secret
APP_JWT_SECRET=change-me-to-at-least-32-characters
# ⚠️ 生产环境必须限制为实际域名 / Production: restrict to actual domains
APP_CORS_ORIGINS=["http://localhost:3000"]
